        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;0-12 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;12-24 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;24-48 Months&quot;&#13;&#10;ELSE &quot;48+ Months&quot;&#13;&#10;END' />
