            <column caption='Churn Flag' datatype='integer' name='[Calculation_0185599076757507]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Monthly Charges Range' datatype='string' name='[Calculation_0185599077146629]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [MonthlyCharges] &lt; 30 THEN &quot;Low&quot;&#13;&#10;ELSEIF [MonthlyCharges] &lt; 70 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
